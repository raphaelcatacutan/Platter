<script lang="ts">
	// Icons and assets
	import {
		check,
		copy,
		copy1,
		darkmode,
		darkmode1,
		darkBg,
		lightBg,
		errorIcon,
		favicon,
		lightmode,
		logo,
		newFile,
		newFile1,
		openFile,
		openFile1,
		refresh,
		refresh1,
		saveFile,
		saveFile1,
		synSemLexIcon,
		synSemLexIcon1,
		table,
		warning
	} from '$lib';
	import { editor as editorSvg } from '$lib/assets';

	// Svelte lifecycle
	import { onMount, onDestroy } from 'svelte';

	// Library modules
	import {
		type Theme,
		type TabType,
		type TermMsg,
		type Token,
		type LexerRow,
		DEFAULT_CODE_SAMPLE,
		logger,
		generateSessionId,
		pyodideManager,
		initializeCodeMirror,
		ErrorMarkerManager,
		normalizeCurlyQuotes as normalizeCurlyQuotesUtil,
		createTerminalHelpers,
		FileOperations,
		analyzeLexical,
		analyzeSyntax,
		analyzeSemantic,
		type AnalyzerContext,
		fetchVersion,
		showFirstVisitCtrlEnterHint,
		syncTerminalPanelHeight as syncPanelHeight,
		handleCopyToClipboard as handleCopyUtil
	} from './lib';

	export let data;

	// Session and version
	let sessionId = generateSessionId();
	let appVersion = '1.0.0';

	// UI state
	let theme: Theme = 'dark';
	let activeTab: TabType = 'lexical';
	let codeInput = DEFAULT_CODE_SAMPLE;

	// Lexer state
	let lexerRows: LexerRow[] = [];
	let tokens: Token[] = [];

	// CodeMirror
	let textareaEl: HTMLTextAreaElement | null = null;
	let cmInstance: any = null;
	let handleGlobalCtrlEnter: ((event: KeyboardEvent) => void) | null = null;

	// DOM references
	let editorPanelEl: HTMLElement | null = null;
	let terminalPanelEl: HTMLElement | null = null;
	let panelSyncObserver: ResizeObserver | null = null;
	let fileInputEl: HTMLInputElement;

	// Terminal state
	let termMessages: TermMsg[] = [];
	let terminalStdinText = '';
	let tacExecutionPaused = false;
	let terminalInputEl: HTMLInputElement | null = null;
	let currentInputLine = '';
	let isResumingExecution = false;
	let lastShownOutputLength = 0;
	let tacInterpreterInstance: any = null;
	let pendingResumeInput = '';
	let accumulatedInputs: string[] = [];

	// Managers
	const errorMarkerManager = new ErrorMarkerManager();
	const terminalHelpers = createTerminalHelpers(check, errorIcon);

	// File operations
	const fileOps = new FileOperations(
		(msg) => setTerminalOk(msg),
		(msg) => setTerminalError(msg)
	);

	// Compute error count
	$: errorCount = termMessages.filter(
		(m) =>
			!(
				typeof m.text === 'string' &&
				(m.text.startsWith('Lexical OK') ||
					m.text.startsWith('No Syntax Error') ||
					m.text.startsWith('Warning:'))
			)
	).length;

	// Compute error count
	$: errorCount = termMessages.filter(
		(m) =>
			!(
				typeof m.text === 'string' &&
				(m.text.startsWith('Lexical OK') ||
					m.text.startsWith('No Syntax Error') ||
					m.text.startsWith('Warning:'))
			)
	).length;

	// Terminal message helpers
	function setTerminalOk(message = 'No Error') {
		termMessages = terminalHelpers.createOkMessage(message);
	}

	function setTerminalError(message: string) {
		termMessages = terminalHelpers.createErrorMessage(message);
	}

	function clearTerminal() {
		termMessages = [];
	}

	// Normalize curly quotes wrapper
	function normalizeCurlyQuotes() {
		if (cmInstance) {
			normalizeCurlyQuotesUtil(cmInstance);
			codeInput = cmInstance.getValue();
		}
	}

	// File operations
	function openFileDialog() {
		normalizeCurlyQuotes();
		fileOps.openFileDialog();
	}

	async function handleFileInput() {
		await fileOps.handleFileInput((code) => {
			codeInput = code;
		});
	}

	async function saveFileDialog() {
		normalizeCurlyQuotes();
		await fileOps.saveFile(codeInput);
	}

	// Theme toggle
	function toggleTheme() {
		normalizeCurlyQuotes();
		theme = theme === 'dark' ? 'light' : 'dark';
	}

	// Copy to clipboard
	async function handleCopyToClipboard() {
		normalizeCurlyQuotes();
		await handleCopyUtil(cmInstance, codeInput, setTerminalOk, setTerminalError);
	}

	// Terminal input handling
	function handleTerminalInputKeydown(event: KeyboardEvent) {
		if (!(event.key === 'Enter' && !event.shiftKey)) return;
		if (!tacExecutionPaused) return;
		event.preventDefault();
		resumeExecution();
	}

	function resumeExecution() {
		if (!tacExecutionPaused) {
			console.log('[Resume] BLOCKED - not paused');
			return;
		}
		console.log('[Resume] User input:', currentInputLine);

		if (currentInputLine) {
			accumulatedInputs = [...accumulatedInputs, currentInputLine];
			console.log('[Resume] Accumulated inputs:', accumulatedInputs);
			currentInputLine = '';
		}

		console.log('[Resume] Re-running program with all inputs');
		tacExecutionPaused = false;
		isResumingExecution = true;
		handleAnalyzeSemantic(true);
	}

	// Auto-focus terminal input when execution pauses
	$: if (tacExecutionPaused) {
		setTimeout(() => {
			if (terminalInputEl) {
				terminalInputEl.focus();
				terminalInputEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			}
		}, 150);
	}

	// Create analyzer context
	function createAnalyzerContext(): AnalyzerContext {
		return {
			pyodide: pyodideManager.instance,
			pyodideReady: pyodideManager.isReady,
			codeInput,
			errorIcon,
			checkIcon: check,
			accumulatedInputs,
			onAddErrorMarkers: (errors) => errorMarkerManager.add(errors),
			onClearErrorMarkers: () => errorMarkerManager.clear(),
			onSetTerminalOk: setTerminalOk,
			onSetTerminalError: setTerminalError,
			onClearTerminal: clearTerminal
		};
	}

	// Analysis functions
	async function handleAnalyzeLexical() {
		normalizeCurlyQuotes();
		activeTab = 'lexical';
		const startTime = performance.now();

		const context = createAnalyzerContext();
		const result = await analyzeLexical(context, false);

		if (result.tokens) tokens = result.tokens;
		if (result.lexerRows) lexerRows = result.lexerRows;

		// Update terminal with error messages if any
		if (result.status === 'error' && result.output) {
			const errorLines = result.output.split('; ');
			termMessages = errorLines.map((text) => ({ icon: errorIcon, text }));
		}

		const duration = performance.now() - startTime;
		logger.addToLogBatch({
			user_id: sessionId,
			source_code: codeInput,
			terminal_output: result.output,
			status: result.status,
			language: `lexical-v${appVersion}`,
			duration_ms: Math.round(duration)
		});
	}

	async function handleAnalyzeSyntax() {
		normalizeCurlyQuotes();
		activeTab = 'syntax';
		const startTime = performance.now();

		const context = createAnalyzerContext();
		await analyzeSyntax(context, analyzeLexical);

		const duration = performance.now() - startTime;
		const terminalOutput = termMessages.map((m) => m.text).join('; ');
		const analysisStatus = termMessages.some((m) => m.icon === errorIcon) ? 'error' : 'success';

		logger.addToLogBatch({
			user_id: sessionId,
			source_code: codeInput,
			terminal_output: terminalOutput,
			status: analysisStatus,
			language: `syntax-v${appVersion}`,
			duration_ms: Math.round(duration)
		});
	}

	async function handleAnalyzeSemantic(runTacInterpreter = false) {
		normalizeCurlyQuotes();
		const startTime = performance.now();

		if (!isResumingExecution) {
			tacExecutionPaused = false;
		}

		const context = createAnalyzerContext();
		const result = await analyzeSemantic(
			context,
			analyzeLexical,
			runTacInterpreter,
			isResumingExecution
		);

		// Handle the result and update terminal messages  
		// (This part contains the complex terminal message handling from the original)
		// For now, simplified version:
		tacExecutionPaused = result.tacExecutionPaused;
		isResumingExecution = false;
		activeTab = 'semantic';

		const duration = performance.now() - startTime;
		const terminalOutput = termMessages.map((m) => m.text).join('; ');
		const analysisStatus = result.success ? 'success' : 'error';

		logger.addToLogBatch({
			user_id: sessionId,
			source_code: codeInput,
			terminal_output: terminalOutput,
			status: analysisStatus,
			language: `${runTacInterpreter ? 'semantic-ir' : 'semantic'}-v${appVersion}`,
			duration_ms: Math.round(duration)
		});
	}

	// Lifecycle: Component mount
	onMount(async () => {
		// Show first-visit hint
		showFirstVisitCtrlEnterHint();

		// Set up keyboard shortcuts
		handleGlobalCtrlEnter = (event: KeyboardEvent) => {
			if (event.defaultPrevented || event.repeat) return;
			if (event.ctrlKey && event.key === 'Enter') {
				event.preventDefault();
				handleAnalyzeSemantic(true);
			} else if (event.ctrlKey && event.key === '1') {
				event.preventDefault();
				handleAnalyzeLexical();
			} else if (event.ctrlKey && event.key === '2') {
				event.preventDefault();
				handleAnalyzeSyntax();
			} else if (event.ctrlKey && event.key === '3') {
				event.preventDefault();
				handleAnalyzeSemantic(false);
			}
		};
		window.addEventListener('keydown', handleGlobalCtrlEnter);
		window.addEventListener('resize', () => syncPanelHeight(editorPanelEl, terminalPanelEl));

		// Initialize CodeMirror
		if (textareaEl) {
			cmInstance = await initializeCodeMirror(
				textareaEl,
				codeInput,
				handleAnalyzeSemantic,
				handleAnalyzeLexical,
				handleAnalyzeSyntax,
				(value) => {
					codeInput = value;
				}
			);

			// Set cmInstance for managers
			errorMarkerManager.setCmInstance(cmInstance);
			fileOps.setCmInstance(cmInstance);
			fileOps.setFileInputElement(fileInputEl);
		}

		// Fetch app version
		appVersion = await fetchVersion(data.basePath);

		// Initialize Pyodide
		await pyodideManager.initialize(data.basePath, setTerminalError);

		// Set up panel height sync
		requestAnimationFrame(() => {
			syncPanelHeight(editorPanelEl, terminalPanelEl);
			if (typeof ResizeObserver !== 'undefined') {
				panelSyncObserver = new ResizeObserver(() =>
					syncPanelHeight(editorPanelEl, terminalPanelEl)
				);
				if (editorPanelEl) panelSyncObserver.observe(editorPanelEl);
				if (terminalPanelEl?.parentElement) panelSyncObserver.observe(terminalPanelEl.parentElement);
			}
		});
	});

	// Lifecycle: Component cleanup
	onDestroy(() => {
		// Cleanup event listeners
		window.removeEventListener('resize', () => syncPanelHeight(editorPanelEl, terminalPanelEl));
		if (panelSyncObserver) {
			panelSyncObserver.disconnect();
			panelSyncObserver = null;
		}

		if (handleGlobalCtrlEnter) {
			window.removeEventListener('keydown', handleGlobalCtrlEnter);
			handleGlobalCtrlEnter = null;
		}

		// Cleanup CodeMirror
		if (cmInstance && typeof cmInstance.toTextArea === 'function') {
			cmInstance.toTextArea();
			cmInstance = null;
		}

		// Cleanup logger
		logger.cleanup();
	});
</script>

			if execution_success:
				print("[Execution OK]")
			elif execution_paused:
				print(f"[Execution Paused] Awaiting input")
