					`;
					const result = await pyodide.runPythonAsync(semanticPythonScript.replace(/\t/g, '    '));

				const data = result.toJs({ dict_converter: Object.fromEntries });

				if (data.success) {
					clearErrorMarkers();
					const semWarningsSuccess: string[] = data.semantic_warnings ? JSON.parse(data.semantic_warnings) : [];
					const warningMarkers = data.error_markers ? JSON.parse(data.error_markers) : [];
					if (warningMarkers.length > 0) addErrorMarkers(warningMarkers);
					const successMsgs: TermMsg[] = [];

					if (runTacInterpreter) {
						// Ctrl+Enter: show runtime-only messages and no check icon.
						if (data.execution_success) {
							if (data.execution_output) {
								// Show full output (we re-run from scratch each time)
								successMsgs.push({ text: data.execution_output });
							}
						} else if (data.execution_paused) {
							if (data.execution_output) {
								// Show full output so far - input will be added inline by resumeExecution
								successMsgs.push({ text: data.execution_output });
							}
							// Don't add separate prompt - input will be inline
						} else {
							// Runtime error occurred
							const errorMsg = data.execution_error || 'Unknown runtime error';
							successMsgs.push({ icon: errorIcon, text: `Runtime Error: ${errorMsg}` });
							console.log('[Terminal] Showing runtime error:', errorMsg);
						}
				} else {
					successMsgs.push({ icon: check, text: data.message || 'No semantic errors' });
					for (const msg of semWarningsSuccess) successMsgs.push({ icon: errorIcon, text: `Warning: ${msg}` });
				}

				// Always replace terminal messages (we re-run from scratch each time)
				termMessages = successMsgs;
				isResumingExecution = false;
				
				console.log('[Terminal] Updated termMessages:', termMessages);
				console.log('[Terminal] Execution paused?', data.execution_paused);
				console.log('[Terminal] Execution success?', data.execution_success);
				const wasPaused = tacExecutionPaused;
				tacExecutionPaused = Boolean(runTacInterpreter && data.execution_paused);
				console.log('[Terminal] tacExecutionPaused changed:', wasPaused, '→', tacExecutionPaused);
						try {
