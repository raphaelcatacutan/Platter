## 2.Perfect # : Sum of it's a proper ddivisors  equals the no.
e.g 
6 = 1+2+3
tell whether the # is a perfect # or not. 
##

piece of num, sum, i;
flag of first = up;
chars of divisorLog = "";
start(){
    sum = 0;
    i = 1;
    divisorLog = "";

    bill("Enter a number: ");
    num = topiece(take());

    repeat(i < num){
        check(num % i == 0){
            sum = sum + i;

            check(not first){
                divisorLog = divisorLog + " + ";
            }

            divisorLog = divisorLog + tochars(i);
            first = down;
        }
        i = i + 1;
    }

    check(sum == num){
        bill(tochars(num) + " = " + divisorLog + "\n");
        bill(tochars(num) + " is a Perfect Number.");
    } instead {
        bill(tochars(num) + " != " + divisorLog + "\n");
        bill(tochars(num) + " is not a Perfect Number.");
    }
}
--end
6
--end
Enter a number: 6
6 = 1 + 2 + 3
6 is a Perfect Number.