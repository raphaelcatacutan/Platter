# Reverse of the Digit

piece of num;
piece of reversed_num , digit= 0;

start(){
    bill("Enter a number: ");
    num = topiece(take());
    repeat (num != 0) {
        digit = num % 10;
        reversed_num = reversed_num * 10 + digit;
        num  = num / 10;
    }
    bill("Reversed Number: " + tochars(reversed_num));
}
--end
1234
--end
Enter a number: 1234
Reversed Number: 4321