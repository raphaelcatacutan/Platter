## Area of the following: Circle, Triangle, Square, Rectangle

Use nested if’s or switch statement for the choices from a-d/1-4, 
if choice is beyond the 4 choices prompt the user “Invalid Input” or possible run time error.
##

start(){
    piece of num = 0;
    sip of pi = 3.14159;
    sip of radius = 0.0;
    sip of base = 0.0;
    sip of height = 0.0;
    sip of side = 0.0;
    sip of length = 0.0;
    sip of width = 0.0;
    sip of area = 0.0;

    order{
        bill("Choose a shape: \n");
        bill("1 - Area of a Circle \n");
        bill("2 - Area of a Triangle \n");
        bill("3 - Area of a Square \n");
        bill("4 - Area of a Rectangle \n");
        bill("Enter your choice (1-4): ");

        num = topiece(take());

        check(num < 1 or num > 4){
            bill("Invalid Input \n");
        } instead {
            menu(num){
                choice 1:
                    repeat(up) {
                        bill("Enter radius: ");
                        radius = tosip(take());
                        check (radius > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative radius\n");
                    }
                    area = pi * radius * radius;
                    bill("Area of Circle: " + tochars(area));
                    stop;

                choice 2:
                    repeat(up) {
                        bill("Enter base: ");
                        base = tosip(take());
                        check (base > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative base\n");
                    }
                    repeat(up) {
                        bill("Enter height: ");
                        height = tosip(take());
                        check (height > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative height\n");
                    }
                    
                    area = (base * height) / 2.0;
                    bill("Area of Triangle: " + tochars(area));
                    stop;

                choice 3:
                    repeat(up) {
                        bill("Enter side: ");
                        side = tosip(take());
                        check (side > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative side\n");
                    }
                    area = side * side;
                    bill("Area of Square: " + tochars(area));
                    stop;

                choice 4:
                    repeat(up) {
                        bill("Enter length: ");
                        length = tosip(take());
                        check (length > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative length\n");
                    }
                    repeat(up) {
                        bill("Enter width: ");
                        width = tosip(take());
                        check (width > 0.0) {stop;}
                        bill("Invalid Input. You can't input a negative width\n");
                    }
                    area = length * width;
                    bill("Area of Rectangle: " + tochars(area));
                    stop;

                usual:
                    bill("Invalid Input \n");
            }
        }
    } repeat(num < 1 or num > 4);
}
--end
5
1
6
--end
