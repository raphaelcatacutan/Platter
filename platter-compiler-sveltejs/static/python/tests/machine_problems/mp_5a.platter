# Multiplaction Table (using arrays)

start(){
        piece of i, v;
        piece of col, row;
                piece[][] of mulTable;
        
        
        bill("Enter number of columns: ");
        col = topiece(take());
        check (col < 1) {
                bill("Not a valid value");
                serve 0;
        }
        
        bill("Enter number of rows: ");
        row = topiece(take());
        check (row < 1) {
                bill("Not a valid value");
                serve 0;
        }
        
        # Calculation
        pass(v = 1; v += 1; v <= row) {
                piece[] of rowLine;
            pass(i = 1; i += 1; i <= col) {
                    rowLine = append(rowLine, v * i);
                   }
            mulTable = append(mulTable, rowLine);
        }
        
        # Printing
        pass(v = 0; v += 1; v < row) {
                piece[] of rowLine;
            rowLine = mulTable[v];
            pass(i = 0; i += 1; i < col) {
                    piece of value = rowLine[i];
                                bill(tochars(value) + "\t");
                   }
            bill("\n");
        }
}
--end
10
10
--end
