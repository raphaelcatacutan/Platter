# Multiplaction Table (using arrays)
start(){
	piece[][] of mulTable; 
    piece of row, col, r, c;
  	
    order{
    row = topiece(bill("Enter table row size: ")+take());
    check(row <= 0) {bill("Invalid row size\n");}
    } repeat(row <= 0);
    
    order{
    col = topiece(bill("Enter table column size: ")+take());
    check(row <= 0) {bill("Invalid column size\n");}
    } repeat(col <= 0);
    
    # Calculation
    pass(r = 1; r += 1; r <= row) {
        piece[] of rowLine;
        pass(c = 1; c += 1; c <= col) {
        	rowLine = append(rowLine, r * c);
        }
        mulTable = append(mulTable, rowLine);
    }
    
    # Printing
    bill("Multiplication Table of size "+tochars(row)+" x "+tochars(col)+":\n");
    pass(r = 0; r += 1; r < row) {
        piece[] of rowLine;
        rowLine = mulTable[r];
        pass(c = 0; c += 1; c < col) {
          piece of value = rowLine[c];
          bill(tochars(value) + "\t");
        }
        bill("\n");
    }
}
--end
10
10
--end
