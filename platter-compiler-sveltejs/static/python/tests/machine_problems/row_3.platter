start(){
                chars of x = "", y = "";
        sip of a, b, result;
        
        bill("Input first number: ");
        x = take();
        bill("Input second number: ");
        y = take();

        a = tosip(x);
        b = tosip(y);

        result = a * b;

        bill("Answer: " + tochars(result));
}
--end
1
1
--end
