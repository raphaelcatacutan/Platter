# Triangle drawing using * input rows (hollow)
start(){
	piece of rows,i,j,k;
	
    order{
      rows = topiece(bill("Enter the number of rows: ")+take());
      check(rows <= 0) {bill("Invalid number of rows\n");}
    } repeat(rows <= 0);
    
    bill("Triangle with "+tochars(rows)+" rows:\n");
    pass(i=0;i+=1;i<rows){
    	# left space padding
    	pass(j=0;j+=1; j<rows-i){
        	bill(" ");
        }
        # asterisks
    	pass(k=i+1;k-=1;k>0){
        	# prints entire first and last row, and first and last asterisk per row
        	check(i == 0 or i == rows - 1 or k == i+1 or k == 1){
              bill("* ");
            } instead{	
              bill("  ");
            }
        }
        bill("\n");
    }
    
}
--end
10
--end
Enter the number of rows: 10
Triangle with 10 rows:
          * 
         * * 
        *   * 
       *     * 
      *       * 
     *         * 
    *           * 
