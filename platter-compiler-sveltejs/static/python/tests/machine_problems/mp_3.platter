# Product of 2 input numbers

start(){
        chars of x = "", y = "";
        sip of a, b, result;
        
        bill("Input first number: ");
        x = take();
        a = tosip(x);
        bill("Input second number: ");
        y = take();
        b = tosip(y);


        result = a * b;

        bill("Answer: " + tochars(result));
}
--end
1
1
--end
Input first number: 1
Input second number: 1
Answer: 1.0