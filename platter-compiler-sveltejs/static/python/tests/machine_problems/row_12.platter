start() {
    piece of side, i, j;
    bill("Enter the side size: ");
    side = topiece(take());

    pass(i = 0; i += 1; i < side) {
        pass(j = 0; j += 1; j < side) {
            bill(" * ");
        }
        bill("\n");
    }
}
--end
6
--end
