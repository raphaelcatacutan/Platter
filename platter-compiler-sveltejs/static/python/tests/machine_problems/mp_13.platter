# Sum of the cube of the numbers from 1 to N

start(){
    piece of i,n,sum;
    bill("Enter a number: ");
    n = topiece(take());
    check (n <= 0) {
        bill("Invalid Number. You can't input numbers less than 1");
        serve 0;
    }
    pass(i = 1; i+=1; i<=n){
        sum += i*i*i;
    }
    bill("The sum of the cube of the numbers from 1 to "+tochars(n)+" is "+tochars(sum));
}
--end
10
--end
Enter a number: 10
The sum of the cube of the numbers from 1 to 10 is 3025