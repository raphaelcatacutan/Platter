# Inverted drawing using * Triangle input rows (hollow)
start(){
	piece of rows,i,j,k;
	
    order{
      rows = topiece(bill("Enter the number of rows: ")+take());
      check(rows <= 0) {bill("Invalid number of rows\n");}
    } repeat(rows <= 0);
    
    bill("Inverted Triangle with "+tochars(rows)+" rows:\n");
    pass(i=0;i+=1;i<rows){
    	# left space padding
    	pass(j=0;j+=1; j<i){
        	bill(" ");
        }
        # asterisks
    	pass(k=rows-i;k-=1;k>0){
        	check(i == 0 or i == rows - 1 or k == rows-i or k == 1){
              	bill("* ");
            } instead {
            	bill("  ");
            }
        }
        bill("\n");
    }
    
}
--end
-7
10
--end
Enter the number of rows: -7
Invalid number of rows
Enter the number of rows: 10
Inverted Triangle with 10 rows:
* * * * * * * * * * 
