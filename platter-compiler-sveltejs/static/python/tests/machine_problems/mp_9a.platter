# Square drawing using * input side length (filled)

start() {
    piece of side, i, j;
    
    order{
      side = topiece(bill("Enter the side length: ")+take());
      check(side <= 0) {bill("Invalid side length\n");}
    } repeat(side <=0 );

	
    bill("Square with side length of "+tochars(side)+": \n");
    pass(i = 0; i += 1; i < side) {
        pass(j = 0; j += 1; j < side) {
            bill(" * ");
        }
        bill("\n");
    }
}
--end
-3
10
--end
