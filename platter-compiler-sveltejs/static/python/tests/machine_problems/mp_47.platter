table of Transaction = [
	piece of kind;
	sip of amount;
	chars of result;
	sip of balance;
];

start(){
	piece of numClients = 0, cIndex = 0;
	flag of isValid = down;

	repeat(not isValid){
		bill("Enter number of clients (1-5): ");
		numClients = topiece(take());

		check(numClients >= 1 and numClients <= 5){
			isValid = up;
		} instead {
			bill("Invalid number of clients. Try again.\n");
		}
	}

	pass(cIndex = 0; cIndex += 1; cIndex < numClients){
		Transaction[] of trxLog = [];
		Transaction of trxItem = [];
		chars of clientName = "", accountNum = "", trxDate = "";
		piece of menuChoice = 0, trxType = 0, trxNo = 0;
		piece of sIndex = 0, depCount = 0, withCount = 0, inqCount = 0;
		sip of balance = 0.0, amount = 0.0;
		sip of dailyDepTotal = 0.0, dailyWithTotal = 0.0;
		sip of depTotal = 0.0, withTotal = 0.0;
		chars of trxResult = "";
		flag of running = up;

		bill("\nClient " + tochars(cIndex + 1) + " information\n");

		bill("Client name: ");
		clientName = take();

		bill("Client account number: ");
		accountNum = take();

		bill("Date (YYYY-MM-DD): ");
		trxDate = take();

		repeat(running){
			bill("\nChoose action:\n");
			bill("1. Deposit\n");
			bill("2. Withdraw\n");
			bill("3. Balance inquiry\n");
			bill("4. Display trxn summary\n");
			bill("5. Exit\n");
			bill("Enter choice: ");
			menuChoice = topiece(take());

			check(menuChoice == 1){
				trxNo = size(trxLog) + 1;
				trxType = 1;
				trxResult = "denied";

				bill("\nTransaction #" + tochars(trxNo) + " for " + clientName + "\n");
				bill("Deposit amount: ");
				amount = tosip(take());

				check(amount <= 0.0){
					bill("Invalid deposit amount.\n");
				} alt(dailyDepTotal + amount > 50000.0){
					bill("Deposit denied. Daily deposit limit is 50000.0\n");
				} instead {
					balance = balance + amount;
					dailyDepTotal = dailyDepTotal + amount;
					trxResult = "ok";
					bill("Deposit successful. Balance: " + tochars(balance) + "\n");
				}

				trxItem = [
					kind = trxType;
					amount = amount;
					result = trxResult;
					balance = balance;
				];
				trxLog = append(trxLog, trxItem);

			} alt(menuChoice == 2){
				trxNo = size(trxLog) + 1;
				trxType = 2;
				trxResult = "denied";

				bill("\nTransaction #" + tochars(trxNo) + " for " + clientName + "\n");
				bill("Withdrawal amount: ");
				amount = tosip(take());

				check(amount <= 0.0){
					bill("Invalid withdrawal amount.\n");
				} alt(dailyWithTotal + amount > 20000.0){
					bill("Withdrawal denied. Daily withdrawal limit is 20000.0\n");
				} alt(amount > balance){
					bill("Withdrawal denied. Amount exceeds balance.\n");
				} instead {
					balance = balance - amount;
					dailyWithTotal = dailyWithTotal + amount;
					trxResult = "ok";
					bill("Withdrawal successful. Balance: " + tochars(balance) + "\n");
				}

				trxItem = [
					kind = trxType;
					amount = amount;
					result = trxResult;
					balance = balance;
				];
				trxLog = append(trxLog, trxItem);

			} alt(menuChoice == 3){
				trxNo = size(trxLog) + 1;
				trxType = 3;
				amount = 0.0;
				trxResult = "ok";

				bill("\nTransaction #" + tochars(trxNo) + " for " + clientName + "\n");
				bill("Balance inquiry. Current balance: " + tochars(balance) + "\n");

				trxItem = [
					kind = trxType;
					amount = amount;
					result = trxResult;
					balance = balance;
				];
				trxLog = append(trxLog, trxItem);

			} alt(menuChoice == 4){
				depCount = 0;
				withCount = 0;
				inqCount = 0;
				depTotal = 0.0;
				withTotal = 0.0;

				pass(sIndex = 0; sIndex += 1; sIndex < size(trxLog)){
					check(trxLog[sIndex]:kind == 1 and trxLog[sIndex]:result == "ok"){
						depCount = depCount + 1;
						depTotal = depTotal + trxLog[sIndex]:amount;
					} alt(trxLog[sIndex]:kind == 2 and trxLog[sIndex]:result == "ok"){
						withCount = withCount + 1;
						withTotal = withTotal + trxLog[sIndex]:amount;
					} alt(trxLog[sIndex]:kind == 3){
						inqCount = inqCount + 1;
					}
				}

				bill("\nTransaction Summary\n");
				bill("Client name: " + clientName + "\n");
				bill("Client account number: " + accountNum + "\n");
				bill("Date: " + trxDate + "\n");
				bill("Total transactions: " + tochars(size(trxLog)) + "\n");
				bill("Deposits made: " + tochars(depCount) + "\n");
				bill("Withdrawals made: " + tochars(withCount) + "\n");
				bill("Balance inquiries: " + tochars(inqCount) + "\n");
				bill("Total deposited: " + tochars(depTotal) + "\n");
				bill("Total withdrawn: " + tochars(withTotal) + "\n");
				bill("Final balance: " + tochars(balance) + "\n");

			} alt(menuChoice == 5){
				check(size(trxLog) >= 5){
					bill("Exit client session.\n");
					running = down;
				} instead {
					bill("At least 5 transactions are required before exit.\n");
				}
			} instead {
				bill("Invalid menu choice.\n");
			}
		}
	}
}
--end
