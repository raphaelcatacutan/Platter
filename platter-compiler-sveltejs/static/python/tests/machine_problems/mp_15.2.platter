# Display the reverse of the digits

prepare piece of reverseDigit(piece of num){
	piece of r = 0;
    repeat(num != 0){
    	piece of rem = num % 10;
        r = r * 10 + rem;
        num = num / 10;
    }
    serve r;
}

start(){
    piece of reverseAnswer, input;
    chars of answer;
    bill("Input a number: ");
    input = topiece(take());
    reverseAnswer = reverseDigit(input);
    answer = tochars(reverseAnswer);
    bill("Reverse of Digits: " + answer);
}
--end
1234
--end
Input a number: 1234
Reverse of Digits: 4321