# Inverted drawing using *Triangle input rows (filled)
start(){
	piece of rows,i,j,k;
	
    order{
      rows = topiece(bill("Enter the number of rows: ")+take());
      check(rows <= 0) {bill("Invalid number of rows\n");}
    } repeat(rows <= 0);
    
    bill("Inverted Triangle with "+tochars(rows)+" rows:\n");
    pass(i=0;i+=1;i<rows){
    	# left space padding
    	pass(j=0;j+=1; j<i){
        	bill(" ");
        }
        # asterisks
    	pass(k=rows-i;k-=1;k>0){
            bill("* ");
        }
        bill("\n");
    }
}
--end
-3
10
--end
