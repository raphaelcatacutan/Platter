# Rectangle drawing using * input height and width (filled)

start() {
    piece of height, width, i, j;   
    
    order{
      width = topiece(bill("Enter the number of width: ")+take());
      check(width <= 0) {bill("Invalid width\n");}
    } repeat(width <= 0);
    
    order{
      height = topiece(bill("Enter the number of height: ")+take());
      check(height <= 0) {bill("Invalid height\n");}
    } repeat(height <= 0);
    
    bill("Rectangle with width of "+tochars(width)+" and height of "+tochars(height)+": \n");
    pass(i = 0; i += 1; i < height) {
        pass(j = 0; j += 1; j < width) {
            bill("* ");
        }
        bill("\n");
    }
}
--end
10
5
--end
Enter the number of width: 10
Enter the number of height: 5
Rectangle with width of 10 and height of 5: 
* * * * * * * * * * 
* * * * * * * * * * 
* * * * * * * * * * 
* * * * * * * * * * 
* * * * * * * * * * 
