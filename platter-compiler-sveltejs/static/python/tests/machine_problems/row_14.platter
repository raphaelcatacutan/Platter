start() {
    piece of row, col, i, j;
    bill("Enter the number of rows: ");
    row =  topiece(take());
    bill("Enter the number of columns: ");
    col =  topiece(take());

    pass(i = 0; i += 1; i < row) {
        pass(j = 0; j += 1; j < col) {
            bill(" * ");
        }
        bill("\n");
    }
}
--end
10
5
--end
