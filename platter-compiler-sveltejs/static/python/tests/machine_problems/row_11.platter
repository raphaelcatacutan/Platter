start() {
    piece of row, i, j;
    row = 9;

    pass(i = row; i -= 1; i >= 1) {
        pass(j = 0; j += 1; j < row - i) {
            bill(" ");
        }

        pass(j = 1; j += 1; j <= (2 * i - 1)) {
            check (j == 1 or j == (2 * i - 1) or i == 1 or i == row) {
                bill("*");
            } instead {
                bill(" ");
            }
        }

        bill("\n");
    }
}
--end
10
--end
