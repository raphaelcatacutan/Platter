## 
Addition of two matrices. Ask the user to input 5 numbers/elements in each array A and Array B, store the sum of the numbers in  Array A & Array B in Array C.
##
prepare piece[] of sumArray(piece[] of A, piece[] of B){
	piece[] of C;
    piece of index = 0;
    check(size(A)==size(B)){
    	repeat(index < size(A)){
        	C = append(C, A[index] + B[index]);
            index+=1;
        }
    } instead {
    	bill("Array sizes are not the same");
    }
    serve C;
}
prepare piece of printNumArray(piece[] of input){
	piece of index = 0;
    repeat(index < size(input)){
    	bill(tochars(input[index])+" ");
        index+=1;
    }
    serve 0;
}
start(){
	piece[] of A = [0,0,0,0,0], B = [0,0,0,0,0];
    piece of index = 0;
    # input for A
    bill("Enter numbers for Array A\n");
   	repeat(index < 5){
    	A[index] = topiece(bill("Number "+tochars(index+1)+": ")+take());
        index+=1;
    }
    # input for B
    index = 0;
    bill("Enter numbers for Array B\n");
   	repeat(index < 5){
    	B[index] = topiece(bill("Number "+tochars(index+1)+": ")+take());
        index+=1;
    }
    bill("Sum of Array A and B in C = [");
    printNumArray(sumArray(A,B));
    bill("]");
}
--end
1
2
3
4
5
