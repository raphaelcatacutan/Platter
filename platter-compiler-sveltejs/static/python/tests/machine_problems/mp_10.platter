# Fibonacci Series (non-recursive)

prepare flag of safeIsPiece(chars of txt, flag of positiveOnly){
    piece of i = 1;
    chars of ch = "";
    flag of hasDigit = down;

    check(txt == ""){
        serve down;
    }

    ch = copy(txt, 1, 1);
    check(ch == "-"){
        check(positiveOnly){
            serve down;
        }
        i = 2;
    }

    repeat(copy(txt, i, i) != ""){
        ch = copy(txt, i, i);
        check(ch >= "0" and ch <= "9"){
            hasDigit = up;
        } instead {
            serve down;
        }
        i = i + 1;
    }

    serve hasDigit;
}
start(){
	piece of N, a = 0, b = 1, i = 0;
    chars of input;
    order{
    	bill("Enter the series length: ");
    	input = take();
        check(not safeIsPiece(input, up) or input == "0"){
        	bill("Invalid input\n");
        }
    } repeat (not safeIsPiece(input, up) or input == "0");
    
    N = topiece(input);
    bill("The fibonacci series of length "+input+" is: ");
    check(N >= 1){
    	bill("0 ");
    }
    
    check(N >= 2){
    	bill("1 ");
    }
    
    repeat(i < N - 2) {
    	piece of c = a + b;
        bill(tochars (c)+" ");
        a = b;
        b = c;
        i += 1;
    }
}
--end
10
--end
