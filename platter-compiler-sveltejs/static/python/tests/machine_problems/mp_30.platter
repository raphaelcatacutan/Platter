# Write a program to find the GCD of two numbers using recursion.   

prepare piece of hcf(piece of n1, piece of n2){
    check(n2 != 0){
        serve hcf(n2, n1 % n2);
    } instead {
        serve n1;
    }
}

start(){
    piece of n1 = 0, n2 = 0, result;
    flag of isValid = down;

    order {
        bill("Enter two positive integers:\n");
        bill("First number: ");
        n1 = topiece(take());
        bill("Second number: ");
        n2 = topiece(take());

        check(n1 > 0 and n2 > 0){
            isValid = up;
        } instead {
            bill("Invalid input. Both numbers must be positive.\n\n");
        }
    } repeat(isValid == down);

    result = hcf(n1, n2);

    bill("G.C.D of " + tochars(n1) + " and " + tochars(n2) + " is " + tochars(result));
}
--end
-10
90
60
6
--end
Enter two positive integers:
First number: -10
Second number: 90
Invalid input. Both numbers must be positive.

Enter two positive integers:
First number: 60
Second number: 6
G.C.D of 60 and 6 is 6