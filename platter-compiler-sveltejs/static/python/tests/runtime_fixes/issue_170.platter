# Runtime overflow error should not include frontend prefix duplication.
prepare piece of factorial(piece of n){
	piece of i = n;
	piece of result = 1;
	repeat(i >= 1){
		result *= i;
		i -= 1;
	}
	serve result;
}

start(){
	piece of num = topiece(take());
	piece of answer = factorial(num);
	bill(tochars(answer));
}
--end
18
--end
[[RUNTIME_ERROR]]Value exceeds range for type piece